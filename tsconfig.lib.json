{
  "compilerOptions": {
    "target": "es2020",
    "lib": ["ES2020", "DOM"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "jsx": "react-jsx",
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "outDir": "lib",
    "rootDir": "src",
    "skipLibCheck": true,
    "strict": true,
    "verbatimModuleSyntax": true,
    "ignoreDeprecations": "6.0"
  },
  "include": ["src/index.ts", "src/Components/**/*.tsx", "src/Components/**/*.ts"]
}
